APP_NAME="Cálculo de Corridas"
APP_ENV=production
APP_KEY=                        # gerar: docker run --rm <image> php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://api.calculocorridas.com
DOMAIN=api.calculocorridas.com

# Registry e tag da imagem (usados pelo stack.yml via Portainer)
REGISTRY=registry.hostdatec.com.br
IMAGE_TAG=v1.0.0

# Logs vão para stderr (visível via docker logs / Portainer)
LOG_CHANNEL=stderr
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=calculo_corridas
DB_USERNAME=corridas_user
DB_PASSWORD=strong_password_here

QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
CACHE_STORE=redis
CACHE_PREFIX=cc_

REDIS_HOST=redis
REDIS_PASSWORD=redis_password_here
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# JWT — Admin Panel
JWT_SECRET=                     # gerar: openssl rand -hex 32
JWT_ALGO=HS256
JWT_TTL=480
JWT_REFRESH_TTL=20160

# Google Play Developer API
GOOGLE_PLAY_PACKAGE_NAME=com.calculocorridas
GOOGLE_PLAY_PRODUCT_ID=pro_monthly
# ATENÇÃO: o JSON deve estar em UMA única linha sem espaços extras
# Espaços internos quebram o parser dotenv do Laravel
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"SEU_PROJETO","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Google Pub/Sub RTDN — token enviado como ?token=... na URL do webhook
RTDN_PUBSUB_TOKEN=              # gerar: openssl rand -hex 24

# Caminhos dos volumes no servidor (Docker Swarm)
POSTGRES_DATA_PATH=/opt/calc-corridas/postgres
REDIS_DATA_PATH=/opt/calc-corridas/redis
STORAGE_DATA_PATH=/opt/calc-corridas/storage
STORAGE_LOGS_PATH=/opt/calc-corridas/logs

# Admin padrão — criado no primeiro seed; troque a senha imediatamente após o deploy
ADMIN_DEFAULT_EMAIL=admin@calculocorridas.com
ADMIN_DEFAULT_PASSWORD=change_me_immediately
