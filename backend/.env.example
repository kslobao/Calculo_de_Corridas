APP_NAME="Cálculo de Corridas"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.calculocorridas.com

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=calculo_corridas
DB_USERNAME=corridas_user
DB_PASSWORD=strong_password_here

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true

CACHE_STORE=redis
CACHE_PREFIX=cc_

REDIS_HOST=redis
REDIS_PASSWORD=redis_password_here
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# JWT — Admin Panel
JWT_SECRET=
JWT_ALGO=HS256
JWT_TTL=1440
JWT_REFRESH_TTL=20160

# Google Play Developer API
GOOGLE_PLAY_PACKAGE_NAME=com.calculocorridas
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Google Pub/Sub RTDN
RTDN_PUBSUB_TOKEN=random_secret_token_for_pubsub_validation

# Rate Limiting
API_RATE_LIMIT=60
API_RATE_LIMIT_WINDOW=1

# Admin
ADMIN_DEFAULT_EMAIL=admin@calculocorridas.com
ADMIN_DEFAULT_PASSWORD=change_me_immediately
